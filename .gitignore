# =============================================================
#  Atelier .gitignore
#  Stack: static HTML/JS SPA + Cloudflare Worker (TypeScript)
#  Dev:   python3 -m http.server + wrangler dev
#  Host:  macOS primary
# =============================================================

# ---------- Project scratch (local-only, never committed) ----
.brainstorming/
.backups/
._docs/

# ---------- macOS noise ----------
.DS_Store
**/.DS_Store
._*
.AppleDouble
.LSOverride
Icon
.Spotlight-V100
.Trashes
.fseventsd
.DocumentRevisions-V100
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ---------- Node / Bun (project uses bun.lock; npm/yarn/pnpm artefacts ignored) ----------
node_modules/
.npm/
.yarn/
.pnp.*
package-lock.json
yarn.lock
pnpm-lock.yaml
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ---------- TypeScript build artefacts ----------
dist/
build/
*.tsbuildinfo

# ---------- Cloudflare Workers / Wrangler ----------
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example
wrangler.toml.bak

# ---------- Logs + crash dumps ----------
*.log
logs/
*.pid
*.seed
*.pid.lock

# ---------- Python (dev server may leave bytecode) ----------
__pycache__/
*.pyc
*.pyo

# ---------- Editor / IDE ----------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
.idea/
*.iml
*.swp
*.swo
*~
.netrwhist
.history/
*.sublime-workspace
*.sublime-project

# ---------- Local env ----------
.env
.env.*
!.env.example
.envrc

# ---------- Coverage / test output ----------
coverage/
.nyc_output/
*.lcov

# ---------- OS / archive cruft ----------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk
# Claude Code worktree cache
.claude/

# Build-time asset manifest (regenerated by scripts/build-manifest.ts).
_manifest.json

# Wire-format bundle (regenerated by scripts/build-bundle.ts). Published
# into the public `.aitelier` fork at release time; never tracked here.
_bundle.br

# Benchmark-only outputs. The scripts and write-ups under .bench/ are
# tracked (they are the reproducible knowledge); the binary artifacts
# and per-sample JSON results are regenerated by .bench/scripts/*.ts.
.bench/artifacts/
.bench/results/

# Playwright raw clips; convert to demo/tour.webp (or .mp4 / .gif) and
# commit that, not the heavy .webm intermediate.
demo/tour-raw/
